# Atlas auth — fill these from your Clerk dashboard, then tell me.
#
# 1. Copy this file to ".env"  (the real .env is gitignored — secrets never get committed)
# 2. Paste your two Clerk keys below
# 3. Tell me "keys are in .env" — I'll read it, set the vars on Railway + Netlify, and you can delete .env
#
# Clerk dashboard → API Keys:
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Backend (@clerk/express) also needs the publishable key under THIS name (it does not
# read the VITE_-prefixed one). Same value as VITE_CLERK_PUBLISHABLE_KEY. Without it,
# clerkMiddleware throws on every request and the server 500s — even /api/health.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Already known (the deployed Railway API) — no need to change:
VITE_API_URL=https://atlas-portal-production-302b.up.railway.app
